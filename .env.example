# Kopiere diese Datei nach .env und trage mindestens einen echten Key ein.
# OpenAI und Google koennen parallel konfiguriert werden.

OPENAI_API_KEY=<dein-openai-api-key>
OPENAI_IMAGE_MODEL=gpt-image-1.5

GOOGLE_API_KEY=<dein-google-api-key>
# Alternativ akzeptiert der Server auch GEMINI_API_KEY.
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview


